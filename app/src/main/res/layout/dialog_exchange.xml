<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/exchange_item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#5B6472"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/exchange_content_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="18dp"
        android:text="我提供的交换物品"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/exchange_content"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_soft_input"
        android:hint="例如：一台九成新的咖啡机"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#111827"
        android:textColorHint="#A0A7B4"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/exchange_remark_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="18dp"
        android:text="交换理由"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/exchange_remark"
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_soft_input"
        android:gravity="top"
        android:hint="写下你的诚意..."
        android:padding="16dp"
        android:textColor="#111827"
        android:textColorHint="#A0A7B4"
        android:textSize="15sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/exchange_submit"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="22dp"
        android:text="提交"
        android:textSize="17sp"
        android:textStyle="bold" />
</LinearLayout>
