<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7F9">

    <LinearLayout
        android:id="@+id/me_page"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/me_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/me_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="我的"
                android:textColor="#111827"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/me_search_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⌕"
                android:textColor="#4B5563"
                android:textSize="28sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/me_profile_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_soft_card"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/me_profile_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/me_avatar_container"
                    android:layout_width="92dp"
                    android:layout_height="92dp" />

                <LinearLayout
                    android:id="@+id/me_identity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/me_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/me_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:textColor="#8E97A8"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/me_edit_profile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/me_contact_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:baselineAligned="false">

                <ImageView
                    android:id="@+id/me_phone_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/phone"
                    android:tint="#5B6472" />

                <TextView
                    android:id="@+id/me_phone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:textColor="#5B6472"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/me_email_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/email"
                    android:tint="#5B6472" />

                <TextView
                    android:id="@+id/me_email"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:textColor="#5B6472"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/me_logout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="退出登录" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/me_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/me_articles"
                style="@style/AppButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="我的帖子" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/me_items"
                style="@style/AppButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="我的物品" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/me_collects"
                style="@style/AppButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="我的收藏" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/me_content_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp" />
    </LinearLayout>
</ScrollView>
