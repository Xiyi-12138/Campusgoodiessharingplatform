<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F6F7F9">

    <LinearLayout
        android:id="@+id/item_detail_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <ImageView
            android:id="@+id/item_detail_image"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:adjustViewBounds="true"
            android:background="#EEEEEE"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/item_detail_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="22dp"
            android:textColor="#111827"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_detail_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textColor="#9AA2B1"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/item_detail_audit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#9AA2B1"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/item_detail_requirement_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_requirement_panel"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:text="交换条件"
            android:textColor="#078061"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_detail_requirement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_requirement_panel"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="16dp"
            android:textColor="#111827"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_detail_description_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp"
            android:text="物品描述"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:textColor="#5B6472"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/item_detail_owner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="18dp"
            android:textColor="#5B6472"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/item_detail_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_detail_collect"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="收藏" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_detail_exchange"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="申请交换" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
